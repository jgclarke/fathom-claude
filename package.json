{
  "name": "fathom-mcp",
  "version": "1.0.0",
  "description": "Remote MCP server for Fathom meeting transcripts — runs on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "predeploy": "npm audit --audit-level=high && tsc --noEmit",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.71.0"
  }
}
